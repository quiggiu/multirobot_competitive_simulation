<?xml version="1.0" ?>
<sdf version="1.8">
  <world name="custom_world">

    <!-- ── Physics ─────────────────────────────────────────── -->
    <physics type="ode">
      <max_step_size>0.001</max_step_size>
      <real_time_factor>1</real_time_factor>
      <real_time_update_rate>1000</real_time_update_rate>
      <ode>
        <solver>
          <type>quick</type>
          <iters>150</iters>
          <precon_iters>0</precon_iters>
          <sor>1.400000</sor>
          <use_dynamic_moi_rescaling>1</use_dynamic_moi_rescaling>
        </solver>
        <constraints>
          <cfm>0.00001</cfm>
          <erp>0.2</erp>
          <contact_max_correcting_vel>2000.000000</contact_max_correcting_vel>
          <contact_surface_layer>0.01000</contact_surface_layer>
        </constraints>
      </ode>
    </physics>

    <!-- ── Plugins ─────────────────────────────────────────── -->
    <plugin filename="gz-sim-physics-system" name="gz::sim::systems::Physics"></plugin>
    <plugin filename="gz-sim-user-commands-system" name="gz::sim::systems::UserCommands"></plugin>
    <plugin filename="gz-sim-scene-broadcaster-system" name="gz::sim::systems::SceneBroadcaster"></plugin>
    <plugin filename="gz-sim-sensors-system" name="gz::sim::systems::Sensors">
      <render_engine>ogre2</render_engine>
    </plugin>
    <plugin filename="gz-sim-imu-system" name="gz::sim::systems::Imu"> </plugin>

        <!--  Ground plane & Sun -->
    <include>
      <uri>https://fuel.gazebosim.org/1.0/OpenRobotics/models/Ground Plane</uri>
    </include>
    <include>
      <uri>https://fuel.gazebosim.org/1.0/OpenRobotics/models/Sun</uri>
    </include>

    <!-- ════════════════════════════════════════════════════════
         ARENA BOUNDARY WALLS
         Arena: x ∈ [-3, 3]  y ∈ [-4, 4]  height = 1 m
         Wall thickness = 0.05 m
    ════════════════════════════════════════════════════════ -->

    <!-- South wall -->
    <model name="wall_south">
      <static>true</static>
      <pose>0 -4 0.5 0 0 0</pose>
      <link name="link">
        <collision name="collision">
          <geometry><box><size>6.0 0.05 1.0</size></box></geometry>
        </collision>
        <visual name="visual">
          <geometry><box><size>6.0 0.05 1.0</size></box></geometry>
          <material><ambient>0.6 0.6 0.6 1</ambient></material>
        </visual>
      </link>
    </model>

    <!-- North wall -->
    <model name="wall_north">
      <static>true</static>
      <pose>0 4 0.5 0 0 0</pose>
      <link name="link">
        <collision name="collision">
          <geometry><box><size>6.0 0.05 1.0</size></box></geometry>
        </collision>
        <visual name="visual">
          <geometry><box><size>6.0 0.05 1.0</size></box></geometry>
          <material><ambient>0.6 0.6 0.6 1</ambient></material>
        </visual>
      </link>
    </model>

    <!-- West wall -->
    <model name="wall_west">
      <static>true</static>
      <pose>-3 0 0.5 0 0 0</pose>
      <link name="link">
        <collision name="collision">
          <geometry><box><size>0.05 8.0 1.0</size></box></geometry>
        </collision>
        <visual name="visual">
          <geometry><box><size>0.05 8.0 1.0</size></box></geometry>
          <material><ambient>0.6 0.6 0.6 1</ambient></material>
        </visual>
      </link>
    </model>

    <!-- East wall -->
    <model name="wall_east">
      <static>true</static>
      <pose>3 0 0.5 0 0 0</pose>
      <link name="link">
        <collision name="collision">
          <geometry><box><size>0.05 8.0 1.0</size></box></geometry>
        </collision>
        <visual name="visual">
          <geometry><box><size>0.05 8.0 1.0</size></box></geometry>
          <material><ambient>0.6 0.6 0.6 1</ambient><diffuse>0.6 0.6 0.6 1</diffuse></material>
        </visual>
      </link>
    </model>

    <!-- Zone divider -->
    <model name="wall_divider">
      <static>true</static>
      <pose>1.0 -1.0 0.5 0 0 0</pose>
      <link name="link">
        <collision name="collision">
          <geometry><box><size>4.0 0.05 1.0</size></box></geometry>
        </collision>
        <visual name="visual">
          <geometry><box><size>4.0 0.05 1.0</size></box></geometry>
          <material><ambient>0.6 0.6 0.6 1</ambient></material>
        </visual>
      </link>
    </model>

    <!-- ════════════════════════════════════════════════════════
         TOP ZONE OBSTACLES
    ════════════════════════════════════════════════════════ -->

    <!--
      box_obstacle_1 : large rectangle (parallelepiped), upper-left quadrant
    -->
    <include>
      <uri>model://box_obstacle</uri>
      <name>box_obstacle_1.1</name>
      <pose>-1.5 0.5 0.5 0 0 0</pose>
    </include>
    <include>
      <uri>model://box_obstacle</uri>
      <name>box_obstacle_1.2</name>
      <pose>-0.5 0.5 0.5 0 0 0</pose>
    </include>
    <include>
      <uri>model://box_obstacle</uri>
      <name>box_obstacle_1.3</name>
      <pose>-1.5 1.5 0.5 0 0 0</pose>
    </include>
    <include>
      <uri>model://box_obstacle</uri>
      <name>box_obstacle_1.4</name>
      <pose>-0.5 1.5 0.5 0 0 0</pose>
    </include>
        <include>
      <uri>model://box_obstacle</uri>
      <name>box_obstacle_1.5</name>
      <pose>-1.5 2.5 0.5 0 0 0</pose>
    </include>
    <include>
      <uri>model://box_obstacle</uri>
      <name>box_obstacle_1.6</name>
      <pose>-0.5 2.5 0.5 0 0 0</pose>
    </include>
    

    <!--
      cylinder_obstacle_1 : upper-right, near top wall
    -->
    <include>
      <uri>model://cylinder_obstacle</uri>
      <name>cylinder_obstacle_1</name>
      <pose>1.5 2.5 0.5 0 0 0</pose>
    </include>

    <!--
      cylinder_obstacle_2 : centre-right
    -->
    <include>
      <uri>model://cylinder_obstacle</uri>
      <name>cylinder_obstacle_2</name>
      <pose>1.5 0.5 0.5 0 0 0</pose>
    </include>

    <!-- ════════════════════════════════════════════════════════
         BOTTOM ZONE OBSTACLES
    ════════════════════════════════════════════════════════ -->

    <!--
      box_obstacle_2 : rectangle in bottom-left of bottom zone
    -->
    <include>
      <uri>model://box_obstacle</uri>
      <name>box_obstacle_2.1</name>
      <pose>-1.5 -2.5 0.5 0 0 0</pose>
    </include>
    <include>
      <uri>model://box_obstacle</uri>
      <name>box_obstacle_2.2</name>
      <pose>-0.5 -2.5 0.5 0 0 0</pose>
    </include>

    <!-- ════════════════════════════════════════════════════════
         SETPOINTS  (green flat discs — no collision)
    ════════════════════════════════════════════════════════ -->

    <!-- TOP ZONE — 3×3 grid of setpoints -->
    <!-- Row 1 : left, centre, right -->
    <include>
      <uri>model://setpoint_marker</uri>
      <name>sp_top_1_1</name>
      <pose>-2.5 3.5 0.01 0 0 0</pose>
    </include>
    <include>
      <uri>model://setpoint_marker</uri>
      <name>sp_top_1_2</name>
      <pose>0.5 3.5 0.01 0 0 0</pose>
    </include>
    <include>
      <uri>model://setpoint_marker</uri>
      <name>sp_top_1_3</name>
      <pose>2.5 3.5 0.01 0 0 0</pose>
    </include>

    <!-- Row 2: right -->
    <include>
      <uri>model://setpoint_marker</uri>
      <name>sp_top_2_3</name>
      <pose>2.5 1.5 0.01 0 0 0</pose>
    </include>

    <!-- Row 3 : left, centre, right -->
    <include>
      <uri>model://setpoint_marker</uri>
      <name>sp_top_3_1</name>
      <pose>-2.5 -0.5 0.01 0 0 0</pose>
    </include>
    <include>
      <uri>model://setpoint_marker</uri>
      <name>sp_top_3_2</name>
      <pose>0.5 -0.5 0.01 0 0 0</pose>
    </include>
    <include>
      <uri>model://setpoint_marker</uri>
      <name>sp_top_3_3</name>
      <pose>2.5 -0.5 0.01 0 0 0</pose>
    </include>

    <!-- BOTTOM ZONE setpoints -->
    <include>
      <uri>model://setpoint_marker</uri>
      <name>sp_bot_1_1</name>
      <pose>-2.5 -2.5 0.01 0 0 0</pose>
    </include>
    <include>
      <uri>model://setpoint_marker</uri>
      <name>sp_bot_1_2</name>
      <pose>0.5 -2.5 0.01 0 0 0</pose>
    </include>

  </world>
</sdf>
